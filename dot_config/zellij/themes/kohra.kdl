// Kohra — cool fog-grey monochrome, mirrored from the WezTerm/Ghostty palette.
// Colour source of truth: ~/dev/kohra. Keep these 16 slots in sync with the
// `kohra` table in dot_config/wezterm/wezterm.lua. Zellij derives the full
// themed UI (tab ribbons, pane frames, status bar) from this 16-colour set.
themes {
    kohra {
        fg "#babec1"
        bg "#181b1d"
        // ANSI normals
        black "#2b2e31"
        red "#b46768"
        green "#768a42"
        yellow "#a57635"
        blue "#3e88b5"
        magenta "#a86893"
        cyan "#1c9388"
        white "#828689"
        // Accent used for highlights/warnings — bright-yellow from the ramp.
        orange "#d2a56d"
    }
}
