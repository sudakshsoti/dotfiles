// Zellij config — stock defaults, theme set to kohra (cool fog-grey monochrome
// with a blue accent, hand-authored from the Kohra cross-app palette — see
// themes/kohra.kdl; vesper-dim and nord-dim are the dimmed built-in alts).
// Everything not set here uses Zellij's compiled-in defaults
// (run `zellij setup --dump-config` to see the full default set).

theme "kohra"

// ── Plugins ───────────────────────────────────────────────────────────────────
// Loaded from release URLs (no binaries in the repo). First launch prompts
// once per plugin to approve permissions — press `y` in the plugin pane.
// The Claude-Code-aware tab bar (zellaude) lives in layouts/default.kdl, since
// it replaces the native tab bar.

keybinds {
    // Fuzzy project → session switcher over ~/dev (tmux-sessionizer style).
    // Reach it via the tmux prefix (Ctrl+b) then `g`.
    tmux {
        bind "g" {
            LaunchOrFocusPlugin "https://github.com/laperlej/zellij-sessionizer/releases/latest/download/zellij-sessionizer.wasm" {
                floating true
                move_to_focused_tab true
                cwd "/"
                root_dirs "/Users/sudakshsoti/dev"
            }
            SwitchToMode "Locked"
        }
        // Override the native new-tab (tmux prefix + `c`) with zellij-newtab-plus:
        // create a tab with a typed name + zoxide directory nav + name history.
        // SwitchToMode "Locked" so the floating plugin receives raw keystrokes.
        bind "c" {
            LaunchOrFocusPlugin "https://github.com/AlexZasorin/zellij-newtab-plus/releases/latest/download/zellij-newtab-plus.wasm" {
                floating true
                use_zoxide true
            }
            SwitchToMode "Locked"
        }
    }
}
