// Zellij config — stock defaults, theme set to vesper-dim (built-in Vesper with a
// darkened status bar — see themes/vesper-dim.kdl; nord-dim is the muted alt).
// Everything not set here uses Zellij's compiled-in defaults
// (run `zellij setup --dump-config` to see the full default set).

theme "vesper-dim"

// ── Plugins ───────────────────────────────────────────────────────────────────
// All loaded from release URLs (no binaries in the repo). First launch prompts
// once per plugin to approve permissions — press `y` in the plugin pane.
// The Claude-Code-aware tab bar (zellaude) lives in layouts/default.kdl, since
// it replaces the native tab bar.
plugins {
    // Auto-locks Zellij while a TUI owns the focused pane (Claude Code, nvim,
    // lazygit, fzf…) so Zellij's Ctrl prefix stops colliding with the app's
    // own keybinds. Unlocks again when you return to a plain shell.
    autolock location="https://github.com/fresh2dev/zellij-autolock/releases/latest/download/zellij-autolock.wasm" {
        is_enabled true
        triggers "nvim|vim|git|fzf|zoxide|atuin|claude|lazygit"
        reaction_seconds "0.3"
        print_to_log false
    }
}

// Background-load autolock so it can watch the focused pane from startup.
load_plugins {
    autolock
}

keybinds {
    // autolock re-evaluates the focused command on each prompt submission;
    // this preserves a normal Enter while notifying the plugin.
    normal {
        bind "Enter" {
            WriteChars "\u{000D}"
            MessagePlugin "autolock"
        }
    }
    // Manually break out of an auto-lock without running a new command.
    locked {
        bind "Alt z" {
            MessagePlugin "autolock" { payload "disable"; }
            SwitchToMode "Normal"
        }
    }
    // Fuzzy project → session switcher over ~/dev (tmux-sessionizer style).
    // Reach it via the tmux prefix (Ctrl+b) then `g`.
    tmux {
        bind "g" {
            LaunchOrFocusPlugin "https://github.com/laperlej/zellij-sessionizer/releases/latest/download/zellij-sessionizer.wasm" {
                floating true
                move_to_focused_tab true
                cwd "/"
                root_dirs "/Users/sudakshsoti/dev"
            }
            SwitchToMode "Locked"
        }
        // Override the native new-tab (tmux prefix + `c`) with zellij-newtab-plus:
        // create a tab with a typed name + zoxide directory nav + name history.
        // SwitchToMode "Locked" so the floating plugin receives raw keystrokes.
        bind "c" {
            LaunchOrFocusPlugin "https://github.com/AlexZasorin/zellij-newtab-plus/releases/latest/download/zellij-newtab-plus.wasm" {
                floating true
                use_zoxide true
            }
            SwitchToMode "Locked"
        }
    }
}
