// Default layout. Replaces the native tab bar with zellaude — a Claude
// Code-aware bar: per-session activity indicators, a pulse + macOS desktop
// notification on permission prompts, click a ⚠ session to focus that exact
// pane, and elapsed-time flags for stuck sessions. The native status bar
// (mode + keybind hints) is kept on the bottom row.
//
// zellaude auto-writes ~/.config/zellij/plugins/zellaude-hook.sh and registers
// it in ~/.claude/settings.json on first load — that live edit must be
// captured back into dot_claude/settings.json (chezmoi source) afterward.
layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="https://github.com/ishefi/zellaude/releases/latest/download/zellaude.wasm"
        }
        children
        pane size=2 borderless=true {
            plugin location="zellij:status-bar"
        }
    }
}
