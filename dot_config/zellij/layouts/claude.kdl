// Claude Code workspace layout — launch with `zellij --layout claude`.
// Wide agent pane (Claude Code) + a narrow shell beside it for git/tests/logs.
// A custom layout must re-declare the tab-bar/status-bar plugins, otherwise the
// builtin chrome won't load — so the full themed bars from config.kdl are kept.
layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        children
        pane size=2 borderless=true {
            plugin location="zellij:status-bar"
        }
    }

    tab name="claude" focus=true {
        pane split_direction="vertical" {
            // Wide pane, focused on open — a plain shell. Launch `claude` here
            // yourself when ready (it creates its own worktree).
            pane size="70%" focus=true name="agent"
            // Lazygit rail — auto-refreshes on filesystem changes, so the agent's
            // edits stream in as a *live* diff to stage/discard/commit. Quitting
            // lazygit (q) drops into a normal interactive shell rather than a
            // re-run prompt. For a deeper, annotatable branch-vs-main review run
            // `rd` (revdiff) from any pane — it auto-floats as a Zellij overlay.
            // (revdiff is one-shot: reload with R, quit with q — not live, which
            // is why lazygit, not revdiff, holds the live rail.)
            pane size="30%" name="git" command="zsh" {
                args "-c" "lazygit; exec zsh"
            }
        }
    }
}
