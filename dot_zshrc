ask() { (cd ~/assistant && claude --permission-mode auto "$@"); }

# wt [name] — create a worktree (random name if none given) and cd into it
wt() {
  emulate -L zsh
  local repo dir name
  repo=$(git rev-parse --show-toplevel 2>/dev/null) || { echo "not in a git repo"; return 1; }
  if [[ -n "$1" ]]; then
    name="$1"
  else
    local adjs=(twinkling frolicking dazzling brave curious mellow nimble cosmic silent gentle wandering radiant
                gleaming velvet rugged jolly drowsy spry breezy amber crimson dapper feral lucid murky
                plucky quiet rowdy sleepy stoic sunny tidy vivid witty zesty bold crisp dim fuzzy keen)
    local nouns=(otter falcon maple cobalt willow ember pixel quartz lumen drift comet harbor
                 badger heron cedar onyx fern spark glyph topaz beacon meadow nebula koi
                 lynx raven birch slate moss flare rune jasper anchor canyon aurora wren)
    name="${adjs[RANDOM % $#adjs + 1]}-${adjs[RANDOM % $#adjs + 1]}-${nouns[RANDOM % $#nouns + 1]}"
  fi
  dir="${repo:h}/worktrees/$name"
  git -C "$repo" worktree add "$dir" -b "$name" || return 1
  cd "$dir" && echo "✓ $name → $dir"
}

