# ============================================================
# PATH
# ============================================================
export PATH="/Users/sudakshsoti/.opencode/bin:$PATH"
export PATH="/Users/sudakshsoti/.antigravity/antigravity/bin:$PATH"
export PATH="$PATH:/Users/sudakshsoti/.local/bin"

# ============================================================
# History
# ============================================================
HISTFILE=~/.zsh_history
HISTSIZE=50000
SAVEHIST=50000
setopt SHARE_HISTORY HIST_IGNORE_ALL_DUPS HIST_IGNORE_SPACE HIST_REDUCE_BLANKS HIST_VERIFY

# ============================================================
# Completions (must come before plugins)
# ============================================================
FPATH="$(brew --prefix)/share/zsh/site-functions:$FPATH"
autoload -Uz compinit && compinit

# ============================================================
# nvm
# ============================================================
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"

# ============================================================
# Python
# ============================================================
alias python='python3'
alias pip='pip3'

# ============================================================
# Homelab
# ============================================================
alias homelab="ssh homelab"
alias homelab-restart="ssh homelab 'cd /opt/stacks && docker compose restart'"
alias homelab-logs="ssh homelab 'cd /opt/stacks && docker compose logs -f'"
alias hlvitals="ssh homelab vitals"
alias hldiag="ssh homelab diag-play"
alias hldf="ssh homelab 'df -h / /mnt/HC_Volume_105268540 && docker system df'"
alias hlps="ssh homelab 'docker ps --format \"table {{.Names}}\t{{.Status}}\"'"

# ============================================================
# General
# ============================================================
alias t="open -a Ghostty"
alias bupdate="brew update && brew upgrade && brew cleanup --prune=all"
alias d="npm run dev"
alias la="ls -A"
alias reload="source ~/.zshrc"
alias zedit="subl ~/.zshrc"
alias c="claude --dangerously-skip-permissions"

# ============================================================
# eza (ls replacement)
# ============================================================
alias ls="eza --group-directories-first --icons=auto"
alias ll="eza -lah --git --icons=auto --group-directories-first"
alias lt="eza --tree --level=2 --icons=auto"

# ============================================================
# Git
# ============================================================
alias gs="git status -sb"
alias gd="git diff"
alias gds="git diff --staged"
alias gl="git log --oneline --graph --decorate -20"
alias gp="git push"
alias gpl="git pull"
alias gf="git fetch --all --prune"
alias gco="git checkout"
alias gcb="git checkout -b"
alias gb="git branch"
alias ga="git add"
alias gaa="git add -A"
alias gcm="git commit -m"
alias gca="git commit -am"
alias gm="git merge"
alias gmnff="git merge --no-ff"
alias gmff="git merge --ff-only"
alias gma="git merge --abort"
alias gmc="git merge --continue"
alias gst="git stash"
alias gstp="git stash pop"

# ============================================================
# System
# ============================================================
alias ports="lsof -iTCP -sTCP:LISTEN -n -P"
alias myip="curl -s https://ifconfig.me && echo"
alias path='echo $PATH | tr ":" "\n"'

# ============================================================
# Functions
# ============================================================
mkcd() { mkdir -p "$1" && cd "$1"; }
gac() { git add -A && git commit -m "$*"; }  # stage everything + commit
killport() { lsof -ti tcp:"$1" | xargs kill -9 2>/dev/null && echo "killed port $1"; }

fcd() {
  local dir
  dir=$(fd --type d --hidden --exclude .git | fzf --preview 'ls -la {}') && cd "$dir"
}

# Lazy-load thefuck (saves ~200ms startup)
fuck() { eval "$(thefuck --alias)"; unfunction fuck; fuck "$@"; }

# ============================================================
# Local overrides
# ============================================================
[ -f ~/.zshrc.local ] && source ~/.zshrc.local

# ============================================================
# fzf
# ============================================================
export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
export FZF_ALT_C_COMMAND='fd --type d --hidden --follow --exclude .git'
export FZF_CTRL_T_OPTS="--preview 'bat --color=always --style=numbers --line-range=:200 {}'"
export FZF_ALT_C_OPTS="--preview 'ls -la {}'"
eval "$(fzf --zsh)"

# ============================================================
# zoxide
# ============================================================
eval "$(zoxide init zsh --cmd cd)"

# ============================================================
# Starship prompt
# ============================================================
eval "$(starship init zsh)"

# ============================================================
# zsh plugins
# Order matters: autosuggestions → history-substring-search → syntax-highlighting (last)
# ============================================================
source /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh
source /opt/homebrew/share/zsh-history-substring-search/zsh-history-substring-search.zsh
bindkey '^[[A' history-substring-search-up
bindkey '^[[B' history-substring-search-down
source /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
