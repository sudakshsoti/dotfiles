fcd() {
  local dir
  dir=$(fd --type d --hidden --exclude .git | fzf --preview 'ls -la {}') && cd "$dir"
}

# Lazy-load thefuck (saves ~200ms startup)
fuck() { eval "$(thefuck --alias)"; unfunction fuck; fuck "$@"; }

