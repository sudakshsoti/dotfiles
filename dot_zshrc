# ============================================================
# fzf
# ============================================================
export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
export FZF_ALT_C_COMMAND='fd --type d --hidden --follow --exclude .git'
export FZF_CTRL_T_OPTS="--preview 'bat --color=always --style=numbers --line-range=:200 {}'"
export FZF_ALT_C_OPTS="--preview 'ls -la {}'"
# Only load fzf's key-binding/completion integration when attached to a real TTY.
# fzf snapshots & restores all shell options (incl. the special `zle` option); in a
# TTY-less interactive shell (e.g. tools that spawn `zsh -i` for snapshots) restoring
# `zle` fails with "can't change option: zle". The bindings are useless without a TTY anyway.
[[ -t 1 ]] && eval "$(fzf --zsh)"

# ============================================================
# Starship prompt
# ============================================================
eval "$(starship init zsh)"

# ============================================================
# zsh plugins
# Order matters: autosuggestions → history-substring-search → syntax-highlighting (last)
# ============================================================
source /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh
source /opt/homebrew/share/zsh-history-substring-search/zsh-history-substring-search.zsh
bindkey '^[[A' history-substring-search-up
bindkey '^[[B' history-substring-search-down
source /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

# ============================================================
# zoxide (must be initialized last — hooks chpwd, not ZLE)
# ============================================================
export _ZO_DOCTOR=0  # suppress the "initialize last" warning (already last; only fires in TTY-less spawns)
eval "$(zoxide init zsh --cmd cd)"

# ============================================================
# difftastic — structural (syntax-aware) diffs
# ============================================================
alias dft='difft'                               # diff two files: dft a.js b.js
alias gdft='GIT_EXTERNAL_DIFF=difft git diff'   # git diff rendered by difftastic

# ============================================================
# git — discard / park working-tree changes
# ============================================================
alias gwipe='git reset --hard HEAD'                       # DESTRUCTIVE: discard all uncommitted tracked changes
alias gpark='git stash push -u -m "gpark $(date +%F\ %T)"' # safe: stash all changes (incl. untracked); restore w/ git stash pop
