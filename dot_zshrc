alias python='python3'
alias pip='pip3'

# opencode
export PATH="/Users/sudakshsoti/.opencode/bin:$PATH"

# antigravity
export PATH="/Users/sudakshsoti/.antigravity/antigravity/bin:$PATH"

# pipx
export PATH="$PATH:/Users/sudakshsoti/.local/bin"

# nvm
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"

# aliases
alias homelab="ssh homelab"
alias homelab-restart="ssh homelab 'cd /opt/stacks && docker compose restart'"
alias homelab-logs="ssh homelab 'cd /opt/stacks && docker compose logs -f'"
alias t="open -a Ghostty"
alias bupdate="brew update && brew upgrade && brew cleanup --prune=all"
alias d="npm run dev"
alias la="ls -A"
alias reload="source ~/.zshrc"
alias c="claude --permission-mode auto"
alias zedit="subl ~/.zshrc"
alias cat="bat"

# local overrides
[ -f ~/.zshrc.local ] && source ~/.zshrc.local

# fzf
export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
export FZF_ALT_C_COMMAND='fd --type d --hidden --follow --exclude .git'
export FZF_CTRL_T_OPTS="--preview 'bat --color=always --style=numbers --line-range=:200 {}'"
export FZF_ALT_C_OPTS="--preview 'ls -la {}'"
eval "$(fzf --zsh)"

# starship prompt
eval "$(starship init zsh)"
