{
  "name": "Editorial Code",
  "type": "dark",
  "semanticHighlighting": true,

  "_palette_reference": {
    "_comment": "Spine rotated to warm hue ~40° (matches Zed source). Syntax wheel kept at original OKLCH coordinates.",
    "spine": {
      "bg.0":   "warm  → #0f0e0c   editor surface",
      "bg.1":   "warm  → #181715   sidebar, panel, active tab",
      "bg.2":   "warm  → #22201d   hover, active line, raised input",
      "bg.3":   "warm  → #2c2a26   peek, structural stroke, hover lift",
      "stroke.indicative":   "warm  → #73716e   focus ring, active state",
      "text.3":  "warm  → #494744   disabled",
      "text.2":  "warm  → #73716e   secondary",
      "text.1":  "warm  → #94928e   comments, gutter, line numbers",
      "text.0":  "warm  → #e6e4e2   primary code, cursor",
      "class_decl":         "→ #c4cfd6   OO class declarations",
      "css_selector_class": "→ #b4e0ef   CSS class selectors"
    },
    "syntax_wheel": {
      "amber  60°":  "oklch(0.78 0.11 60)  → #eba66d   strings",
      "olive 110°":  "oklch(0.76 0.10 110) → #b5b76a   numbers, booleans",
      "teal  160°":  "oklch(0.76 0.10 160) → #75c59b   functions, methods",
      "blue  220°":  "oklch(0.74 0.13 220) → #1ebde3   keywords",
      "violet 280°": "oklch(0.74 0.11 280) → #9da3ef   types, classes, interfaces",
      "rose  340°":  "oklch(0.76 0.11 340) → #e095c7   constants, builtins, language values"
    },
    "diagnostics": {
      "error":   "#de4e4b",
      "warning": "#eba941",
      "info":    "#43b2e1",
      "hint":    "#94928e"
    },
    "git_gutter": {
      "added":    "#67b36a",
      "modified": "#eba941",
      "deleted":  "#de4e4b"
    }
  },

