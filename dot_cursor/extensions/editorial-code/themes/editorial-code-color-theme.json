  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "comment.line",
        "comment.block",
        "comment.block.documentation",
        "punctuation.definition.comment"
      ],
      "settings": { "foreground": "#94928e" }
    },
    {
      "name": "JSDoc / TSDoc tags",
      "scope": [
        "storage.type.class.jsdoc",
        "punctuation.definition.block.tag.jsdoc",
        "storage.type.class.tsdoc"
      ],
      "settings": { "foreground": "#73716e" }
    },
    {
      "name": "Punctuation: structural, neutral",
      "scope": [
        "punctuation",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.section",
        "punctuation.definition.tag",
        "punctuation.definition.parameters",
        "punctuation.definition.array",
        "punctuation.definition.string",
        "punctuation.definition.dictionary",
        "punctuation.support.type.property-name",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": { "foreground": "#94928e" }
    },
    {
      "name": "Operators: neutral",
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic",
        "keyword.operator.comparison",
        "keyword.operator.logical",
        "keyword.operator.bitwise",
        "keyword.operator.expression",
        "keyword.operator.spread",
        "keyword.operator.rest",
        "storage.modifier.async",
        "storage.modifier.await"
      ],
      "settings": { "foreground": "#94928e" }
    },

    {
      "name": "Strings (60° amber)",
      "scope": [
        "string",
        "string.quoted.single",
        "string.quoted.double",
        "string.quoted.triple",
        "string.unquoted",
        "string.template",
        "string.regexp",
        "punctuation.definition.string.begin",
        "punctuation.definition.string.end",
        "meta.string"
      ],
      "settings": { "foreground": "#eba66d" }
    },
    {
      "name": "Template string interpolation punctuation",
      "scope": [
        "punctuation.definition.template-expression",
        "punctuation.section.embedded"
      ],
      "settings": { "foreground": "#94928e" }
    },
    {
      "name": "Escape sequences inside strings",
      "scope": [
        "constant.character.escape",
        "constant.character.escape.regexp",
        "constant.other.placeholder"
      ],
      "settings": { "foreground": "#75c59b" }
    },
    {
      "name": "Regex grouping and quantifiers",
      "scope": [
        "string.regexp punctuation",
        "string.regexp keyword.operator",
        "string.regexp keyword.control.anchor",
        "string.regexp constant.other.character-class"
      ],
      "settings": { "foreground": "#94928e" }
    },

    {
      "name": "Numbers, booleans (110° olive)",
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float",
        "constant.numeric.decimal",
        "constant.numeric.hex",
        "constant.numeric.binary",
        "constant.numeric.octal",
        "constant.language.boolean",
        "constant.language.true",
        "constant.language.false"
      ],
      "settings": { "foreground": "#b5b76a" }
    },

    {
      "name": "Functions, methods, calls (160° teal)",
      "scope": [
        "entity.name.function",
        "entity.name.function.call",
        "entity.name.function.member",
        "meta.function-call entity.name.function",
        "meta.function entity.name.function",
        "support.function",
        "support.function.builtin",
        "variable.function",
        "meta.method.declaration entity.name.function"
      ],
      "settings": { "foreground": "#75c59b" }
    },

    {
      "name": "Keywords, control flow (220° blue)",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.control.flow",
        "keyword.control.conditional",
        "keyword.control.loop",
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.as",
        "keyword.control.default",
        "keyword.control.return",
        "keyword.control.trycatch",
        "keyword.control.new",
        "keyword.control.delete",
        "keyword.other",
        "keyword.declaration",
        "storage.type",
        "storage.type.function",
        "storage.type.class",
        "storage.type.interface",
        "storage.type.enum",
        "storage.type.namespace",
        "storage.type.var",
        "storage.type.let",
        "storage.type.const",
        "storage.modifier",
        "storage.modifier.access",
        "storage.modifier.export",
        "storage.modifier.import",
        "storage.modifier.static",
        "storage.modifier.abstract",
        "storage.modifier.public",
        "storage.modifier.private",
        "storage.modifier.protected",
        "storage.modifier.readonly"
      ],
      "settings": { "foreground": "#1ebde3" }
    },

    {
      "name": "Class declarations (split from types — mirrors Zed `class` token)",
      "scope": [
        "entity.name.class",
        "entity.name.type.class",
        "support.class",
        "support.class.builtin",
        "entity.other.inherited-class",
        "meta.class entity.name.class"
      ],
      "settings": { "foreground": "#c4cfd6" }
    },
    {
      "name": "Types, interfaces, enums (280° violet)",
      "scope": [
        "entity.name.type",
        "entity.name.type.interface",
        "entity.name.type.enum",
        "entity.name.type.alias",
        "entity.name.type.module",
        "entity.name.type.parameter",
        "entity.name.namespace",
        "support.type",
        "support.type.primitive",
        "support.type.builtin",
        "meta.type.declaration entity.name.type",
        "meta.interface entity.name.type"
      ],
      "settings": { "foreground": "#9da3ef" }
    },

    {
      "name": "Constants, builtins, language values (340° rose)",
      "scope": [
        "constant",
        "constant.language",
        "constant.language.null",
        "constant.language.undefined",
        "constant.language.nan",
        "constant.language.infinity",
        "constant.language.this",
        "constant.language.super",
        "variable.language.this",
        "variable.language.self",
        "variable.language.super",
        "support.constant",
        "support.variable",
        "constant.other"
      ],
      "settings": { "foreground": "#e095c7" }
    },

    {
      "name": "Variables: primary text",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "variable.other.constant",
        "variable.other.member",
        "variable.other.property",
        "variable.other.object",
        "variable.other.object.property",
        "variable.parameter",
        "meta.parameters variable.parameter",
        "meta.definition.variable variable.other"
      ],
      "settings": { "foreground": "#e6e4e2" }
    },
    {
      "name": "Decorators",
      "scope": [
        "meta.decorator",
        "meta.decorator entity.name.function",
        "tag.decorator",
        "punctuation.decorator"
      ],
      "settings": { "foreground": "#9da3ef" }
    },

    {
      "name": "Markup: headings",
      "scope": [
        "markup.heading",
        "markup.heading entity.name",
        "entity.name.section.markdown",
        "punctuation.definition.heading.markdown"
      ],
      "settings": { "foreground": "#e6e4e2", "fontStyle": "bold" }
    },
    {
      "name": "Markup: bold",
      "scope": ["markup.bold", "punctuation.definition.bold"],
      "settings": { "foreground": "#e6e4e2", "fontStyle": "bold" }
    },
    {
      "name": "Markup: italic",
      "scope": ["markup.italic", "punctuation.definition.italic"],
      "settings": { "foreground": "#e6e4e2", "fontStyle": "italic" }
    },
    {
      "name": "Markup: bold+italic",
      "scope": ["markup.bold markup.italic", "markup.italic markup.bold"],
      "settings": { "foreground": "#e6e4e2", "fontStyle": "bold italic" }
    },
    {
      "name": "Markup: strikethrough",
      "scope": ["markup.strikethrough"],
      "settings": { "foreground": "#73716e", "fontStyle": "strikethrough" }
    },
    {
      "name": "Markup: blockquote",
      "scope": ["markup.quote", "punctuation.definition.quote"],
      "settings": { "foreground": "#94928e", "fontStyle": "italic" }
    },
    {
      "name": "Markup: link text",
      "scope": [
        "markup.underline.link",
        "string.other.link",
        "markup.underline.link.image"
      ],
      "settings": { "foreground": "#1ebde3" }
    },
    {
      "name": "Markup: link title",
      "scope": ["string.other.link.title", "string.other.link.description"],
      "settings": { "foreground": "#75c59b" }
    },
    {
      "name": "Markup: inline code",
      "scope": ["markup.inline.raw", "markup.raw.inline", "markup.fenced_code"],
      "settings": { "foreground": "#eba66d" }
    },
    {
      "name": "Markup: lists",
      "scope": [
        "markup.list",
        "punctuation.definition.list.begin",
        "markup.list.unnumbered.markdown",
        "markup.list.numbered.markdown"
      ],
      "settings": { "foreground": "#94928e" }
    },
    {
      "name": "Markup: HRs and separators",
      "scope": [
        "meta.separator",
        "punctuation.definition.thematic-break"
      ],
      "settings": { "foreground": "#494744" }
    },

    {
      "name": "HTML / JSX / Vue tags",
      "scope": [
        "entity.name.tag",
        "entity.name.tag.html",
        "entity.name.tag.xml",
        "entity.name.tag.jsx",
        "entity.name.tag.tsx",
        "support.class.component",
        "support.class.component.jsx",
        "support.class.component.tsx",
        "punctuation.definition.tag"
      ],
      "settings": { "foreground": "#1ebde3" }
    },
    {
      "name": "HTML / JSX attributes",
      "scope": [
        "entity.other.attribute-name",
        "entity.other.attribute-name.html",
        "entity.other.attribute-name.jsx",
        "entity.other.attribute-name.tsx"
      ],
      "settings": { "foreground": "#9da3ef" }
    },
    {
      "name": "JSX braces",
      "scope": [
        "punctuation.section.embedded.begin.jsx",
        "punctuation.section.embedded.end.jsx",
        "punctuation.section.embedded.begin.tsx",
        "punctuation.section.embedded.end.tsx"
      ],
      "settings": { "foreground": "#94928e" }
    },

    {
      "name": "CSS / SCSS tags",
      "scope": ["entity.name.tag.css", "entity.name.tag.scss"],
      "settings": { "foreground": "#1ebde3" }
    },
    {
      "name": "CSS class selectors (mirrors Zed `selector.class`)",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.class.scss",
        "entity.other.attribute-name.parent-selector.css"
      ],
      "settings": { "foreground": "#b4e0ef" }
    },
    {
      "name": "CSS id selectors",
      "scope": ["entity.other.attribute-name.id.css"],
      "settings": { "foreground": "#e095c7" }
    },
    {
      "name": "CSS pseudo-classes / pseudo-elements",
      "scope": [
        "entity.other.attribute-name.pseudo-class.css",
        "entity.other.attribute-name.pseudo-element.css"
      ],
      "settings": { "foreground": "#75c59b" }
    },
    {
      "name": "CSS property names",
      "scope": [
        "support.type.property-name.css",
        "support.type.property-name.scss",
        "meta.property-name"
      ],
      "settings": { "foreground": "#e6e4e2" }
    },
    {
      "name": "CSS property values",
      "scope": [
        "support.constant.property-value.css",
        "support.constant.property-value.scss",
        "constant.other.color.rgb-value.css",
        "support.constant.color.w3c-standard-color-name.css"
      ],
      "settings": { "foreground": "#e095c7" }
    },
    {
      "name": "CSS units",
      "scope": [
        "keyword.other.unit",
        "keyword.other.unit.px.css",
        "keyword.other.unit.percentage.css"
      ],
      "settings": { "foreground": "#b5b76a" }
    },
    {
      "name": "CSS at-rules",
      "scope": [
        "keyword.control.at-rule",
        "punctuation.definition.keyword.css"
      ],
      "settings": { "foreground": "#1ebde3" }
    },
    {
      "name": "CSS variables",
      "scope": [
        "variable.argument.css",
        "variable.css",
        "variable.scss",
        "variable.other.custom-property"
      ],
      "settings": { "foreground": "#e6e4e2" }
    },
    {
      "name": "CSS function names",
      "scope": [
        "support.function.misc.css",
        "support.function.calc.css",
        "support.function.var.css"
      ],
      "settings": { "foreground": "#75c59b" }
    },

    {
      "name": "JSON keys",
      "scope": ["support.type.property-name.json"],
      "settings": { "foreground": "#e6e4e2" }
    },
    {
      "name": "JSON string values",
      "scope": ["meta.structure.dictionary.value.json string.quoted"],
      "settings": { "foreground": "#eba66d" }
    },

    {
      "name": "YAML keys",
      "scope": ["entity.name.tag.yaml"],
      "settings": { "foreground": "#9da3ef" }
    },
    {
      "name": "YAML scalar values",
      "scope": ["string.unquoted.plain.out.yaml", "string.unquoted.block.yaml"],
      "settings": { "foreground": "#e6e4e2" }
    },

    {
      "name": "Python functions",
      "scope": ["support.type.python", "meta.function.python entity.name.function"],
      "settings": { "foreground": "#75c59b" }
    },
    {
      "name": "Python decorators",
      "scope": ["meta.function.decorator.python entity.name.function"],
      "settings": { "foreground": "#9da3ef" }
    },
    {
      "name": "Python self / cls",
      "scope": ["variable.parameter.function.language.special.self.python", "variable.parameter.function.language.special.cls.python"],
      "settings": { "foreground": "#e095c7" }
    },
    {
      "name": "Python f-string interpolation braces",
      "scope": [
        "meta.embedded.expression.python punctuation.section.embedded"
      ],
      "settings": { "foreground": "#94928e" }
    },

    {
      "name": "Shell variables",
      "scope": ["variable.other.normal.shell", "variable.parameter.shell"],
      "settings": { "foreground": "#e6e4e2" }
    },
    {
      "name": "Shell command substitution",
      "scope": ["meta.scope.case-block.shell", "string.interpolated.dollar.shell"],
      "settings": { "foreground": "#75c59b" }
    },

    {
      "name": "Diff: inserted",
      "scope": ["markup.inserted", "meta.diff.header.from-file", "punctuation.definition.inserted"],
      "settings": { "foreground": "#67b36a" }
    },
    {
      "name": "Diff: deleted",
      "scope": ["markup.deleted", "meta.diff.header.to-file", "punctuation.definition.deleted"],
      "settings": { "foreground": "#de4e4b" }
    },
    {
      "name": "Diff: changed",
      "scope": ["markup.changed", "punctuation.definition.changed"],
      "settings": { "foreground": "#eba941" }
    },
    {
      "name": "Diff: range header",
      "scope": ["meta.diff.range", "meta.diff.header"],
      "settings": { "foreground": "#9da3ef" }
    },

    {
      "name": "Invalid",
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#de4e4b" }
    },
    {
      "name": "Deprecated",
      "scope": ["invalid.deprecated"],
      "settings": { "foreground": "#94928e", "fontStyle": "strikethrough" }
    }
  ],

  "semanticTokenColors": {
    "namespace":          "#9da3ef",
    "type":               "#9da3ef",
    "class":              "#c4cfd6",
    "interface":          "#9da3ef",
    "enum":               "#9da3ef",
    "struct":             "#9da3ef",
    "typeParameter":      "#9da3ef",

    "function":           "#75c59b",
    "method":             "#75c59b",
    "decorator":          "#9da3ef",

    "macro":              "#e095c7",
    "label":              "#94928e",

    "variable":           "#e6e4e2",
    "parameter":          "#e6e4e2",
    "property":           "#e6e4e2",
    "enumMember":         "#e095c7",
    "event":              "#1ebde3",

    "string":             "#eba66d",
    "number":             "#b5b76a",
    "boolean":            "#b5b76a",

    "keyword":            "#1ebde3",
    "modifier":           "#1ebde3",
    "operator":           "#94928e",

    "comment":            "#94928e",
    "regexp":             "#eba66d",

    "*.declaration":          { "fontStyle": "" },
    "*.deprecated":           { "fontStyle": "strikethrough" },
    "*.readonly":             { "fontStyle": "" },
    "*.defaultLibrary":       { "foreground": "#e095c7" },
    "variable.defaultLibrary":{ "foreground": "#e095c7" },
    "function.defaultLibrary":{ "foreground": "#75c59b" },
    "class.defaultLibrary":   { "foreground": "#c4cfd6" }
  }
}
