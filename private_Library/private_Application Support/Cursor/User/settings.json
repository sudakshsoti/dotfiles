{
    "claudeCode.preferredLocation": "panel",
    "workbench.colorTheme": "Vesper Extended",
    "git.autofetch": true,
    "git.enableSmartCommit": true,

    "editor.fontFamily": "MonoLisa Nerd Font",
    "editor.fontSize": 13,
    "editor.fontWeight": "450",
    "editor.fontLigatures": "'liga', 'calt', 'cv11', 'ss03'",
    "editor.lineHeight": 1.6,
    "editor.cursorBlinking": "solid",
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.renderWhitespace": "selection",
    "editor.guides.indentation": true,

    "terminal.integrated.fontFamily": "MonoLisa Nerd Font",
    "terminal.integrated.fontSize": 13,
    "terminal.integrated.fontWeight": "500",
    "terminal.integrated.cursorStyle": "line",

    "window.titleBarStyle": "custom",
    "workbench.iconTheme": null,
    "chat.editor.fontFamily": "Inter",
    "markdown.preview.fontFamily": "Inter",

    "editor.tokenColorCustomizations": {
        "[Vesper Extended]": {
            "comments": "#6A6359",
            "textMateRules": [
                { "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#6A6359", "fontStyle": "italic" } },
                { "scope": ["comment.block.documentation", "comment.line.documentation"], "settings": { "foreground": "#9C9388", "fontStyle": "italic" } },
                { "scope": ["keyword", "keyword.control", "storage", "storage.type", "storage.modifier"], "settings": { "foreground": "#FFC799" } },
                { "scope": ["keyword.operator"], "settings": { "foreground": "#9C9388" } },
                { "scope": ["entity.name.function", "support.function", "meta.function-call.generic", "meta.function.call"], "settings": { "foreground": "#99FFE4", "fontStyle": "" } },
                { "scope": ["string", "string.quoted", "string.template", "punctuation.definition.string"], "settings": { "foreground": "#99FFE4" } },
                { "scope": ["constant.character.escape", "constant.other.placeholder"], "settings": { "foreground": "#FFC799" } },
                { "scope": ["string.regexp", "string.regex"], "settings": { "foreground": "#C7A4F0" } },
                { "scope": ["constant.numeric", "constant.language.boolean", "constant.language.null", "constant.language.undefined"], "settings": { "foreground": "#EA9988" } },
                { "scope": ["constant", "constant.language", "variable.other.constant", "support.constant"], "settings": { "foreground": "#C7A4F0" } },
                { "scope": ["entity.name.type", "support.type", "support.class", "entity.name.class", "entity.other.inherited-class"], "settings": { "foreground": "#C7A4F0" } },
                { "scope": ["variable.language", "variable.language.this", "variable.language.self"], "settings": { "foreground": "#C7A4F0", "fontStyle": "italic" } },
                { "scope": ["variable", "variable.other", "variable.parameter"], "settings": { "foreground": "#E6E2DD" } },
                { "scope": ["variable.other.property", "support.type.property-name", "meta.object-literal.key", "meta.property.object", "entity.other.attribute-name"], "settings": { "foreground": "#F2C879" } },
                { "scope": ["entity.name.tag", "punctuation.definition.tag", "meta.tag"], "settings": { "foreground": "#FFC799" } },
                { "scope": ["meta.decorator", "entity.name.function.decorator", "punctuation.decorator"], "settings": { "foreground": "#C7A4F0", "fontStyle": "italic" } },
                { "scope": ["punctuation", "punctuation.separator", "punctuation.terminator", "meta.brace", "punctuation.section"], "settings": { "foreground": "#7E7770" } },
                { "scope": ["markup.list.unnumbered.bullet", "markup.list.numbered.bullet", "punctuation.definition.list_item"], "settings": { "foreground": "#FFC799" } },
                { "scope": ["markup.bold"], "settings": { "foreground": "#E6E2DD", "fontStyle": "bold" } },
                { "scope": ["markup.italic"], "settings": { "foreground": "#E6E2DD", "fontStyle": "italic" } },
                { "scope": ["markup.heading", "entity.name.section"], "settings": { "foreground": "#FFC799", "fontStyle": "bold" } },
                { "scope": ["markup.inline.raw", "markup.fenced_code"], "settings": { "foreground": "#99FFE4" } },
                { "scope": ["markup.underline.link", "string.other.link"], "settings": { "foreground": "#99FFE4", "fontStyle": "italic" } },
                { "scope": ["markup.link", "constant.other.reference.link"], "settings": { "foreground": "#6A6359" } },
                { "scope": ["entity.name.label"], "settings": { "foreground": "#F2C879" } },
                { "scope": ["constant.other.symbol"], "settings": { "foreground": "#F2C879" } }
            ]
        }
    },

